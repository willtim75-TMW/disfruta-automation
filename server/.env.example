# Server
PORT=3001
NODE_ENV=development
# Shared secret must match webform/js/config.js → webhookSecret (optional but recommended)
ORDER_WEBHOOK_SECRET=change-me-to-a-long-random-string
# Comma-separated origins allowed to call the API (webform host)
CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# QuickBooks Online app (https://developer.intuit.com)
# Create an app → Keys & OAuth → copy Client ID / Secret
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# Must match the Redirect URI registered on the Intuit app
QBO_REDIRECT_URI=http://localhost:3001/auth/quickbooks/callback
# sandbox | production
QBO_ENVIRONMENT=sandbox
# Company ID (realmId) from OAuth callback or QBO URL
QBO_REALM_ID=

# Tokens — filled by: npm run auth  (or paste from OAuth callback)
QBO_ACCESS_TOKEN=
QBO_REFRESH_TOKEN=
# ISO timestamp when access token expires (optional; refresh runs proactively)
QBO_TOKEN_EXPIRES_AT=

# Invoice defaults
# Create as draft for owner review (true) or finalized (false)
QBO_INVOICE_AS_DRAFT=true
# Optional: default sales tax code NON / TAX — leave blank to omit TaxCodeRef
QBO_DEFAULT_TAX_CODE=
# Customer memo on every invoice
QBO_CUSTOMER_MEMO=Thank you for your order with DisFruta!
